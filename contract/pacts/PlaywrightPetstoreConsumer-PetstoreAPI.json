{
  "consumer": {
    "name": "PlaywrightPetstoreConsumer"
  },
  "interactions": [
    {
      "description": "a request to find pets by status=available",
      "providerStates": [
        {
          "name": "at least one available pet exists"
        }
      ],
      "request": {
        "headers": {
          "Accept": "application/json"
        },
        "method": "GET",
        "path": "/api/v3/pet/findByStatus",
        "query": {
          "status": [
            "available"
          ]
        }
      },
      "response": {
        "body": [
          {
            "id": 101,
            "name": "doggie",
            "photoUrls": [
              "https://example.com/photo.jpg"
            ],
            "status": "available"
          }
        ],
        "generators": {
          "body": {
            "$[*].id": {
              "max": 10,
              "min": 0,
              "type": "RandomInt"
            }
          }
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$[*].name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^.+$"
                }
              ]
            },
            "$[*].photoUrls": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$[*].photoUrls[*]": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^https?:\\/\\/[\\w-]+(\\.[\\w-]+)+(\\/[\\w\\-./?%&=]*)?$"
                }
              ]
            },
            "$[*].status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^(available|pending|sold)$"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
